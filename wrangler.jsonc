{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "micirql-dms",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "capdent.micirql.com",
      "custom_domain": true
    }
  ]
}
